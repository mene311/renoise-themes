# Required — generate with: openssl rand -hex 32
SESSION_SECRET=your-super-secret-random-string-here-min-32-chars

# Resend email API key — get at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@renoisethemes.com

# Deploy webhook secret — generate with: openssl rand -hex 32
DEPLOY_SECRET=your-deploy-secret-for-github-webhook

# Production
NODE_ENV=production
PORT=3000
