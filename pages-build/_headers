{
  "build": {
    "command": "echo 'Static site - no build process needed'",
    "publish": "docs"
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/docs/index.html",
      "status": 200
    }
  ],
  "headers": [
    {
      "source": "/docs/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}