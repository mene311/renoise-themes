<%- include('partials/header', { pageTitle: 'Feedback Admin — Renoise Theme Share' }) %>

<style>
  .admin-page { max-width: 900px; margin: 24px auto; padding: 0 16px; }
  .admin-page h1 { font-size: 1.2rem; margin-bottom: 16px; }
  .admin-tabs { display: flex; gap: 8px; margin-bottom: 16px; }
  .admin-tabs a { padding: 6px 14px; font-size: 13px; text-decoration: none; border: 1px solid var(--chrome-border); color: var(--chrome-text-dim); }
  .admin-tabs a.active { background: var(--accent); color: #111; border-color: var(--accent); }
  .feedback-item { background: var(--chrome-bg); border: 1px solid var(--chrome-border); padding: 12px 16px; margin-bottom: 8px; }
  .feedback-item.unread { border-left: 3px solid var(--accent); }
  .feedback-meta { display: flex; gap: 16px; font-size: 11px; color: var(--chrome-text-faint); margin-bottom: 6px; }
  .feedback-message { font-size: 14px; color: var(--chrome-text-dim); line-height: 1.6; white-space: pre-wrap; }
  .feedback-actions { margin-top: 8px; }
  .feedback-reply { margin-top: 8px; }
  .feedback-reply summary { cursor: pointer; font-size: 12px; color: var(--accent); }
  .feedback-reply textarea { width: 100%; margin: 8px 0; background: var(--chrome-panel); color: var(--chrome-text); border: 1px solid var(--chrome-border); padding: 8px; font-family: inherit; font-size: 13px; }
  .feedback-replied { margin-top: 8px; font-size: 11px; color: var(--accent); }
  .empty { text-align: center; color: var(--chrome-text-faint); padding: 40px; }
</style>

<div class="admin-page">
  <a href="/" class="back-link">&larr; Back</a>
  <h1>Feedback</h1>

  <div class="admin-tabs">
    <a href="?filter=all" class="<%= filter === 'all' ? 'active' : '' %>">All</a>
    <a href="?filter=unread" class="<%= filter === 'unread' ? 'active' : '' %>">Unread</a>
    <a href="?filter=read" class="<%= filter === 'read' ? 'active' : '' %>">Read</a>
  </div>

  <% if (items.length === 0) { %>
    <div class="empty">No feedback yet.</div>
  <% } else { %>
    <% items.forEach(item => { %>
      <div class="feedback-item <%= item.read ? '' : 'unread' %>">
        <div class="feedback-meta">
          <% if (item.name) { %><span>From: <strong><%= item.name %></strong></span><% } %>
          <% if (item.email) { %><span><%= item.email %></span><% } %>
          <span><%= new Date(item.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
        </div>
        <div class="feedback-message"><%= item.message %></div>
        <% if (item.replied_at) { %>
          <div class="feedback-replied">Replied <%= new Date(item.replied_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></div>
        <% } %>
        <div class="feedback-actions">
          <% if (!item.read) { %>
            <form method="POST" action="/admin/feedback/<%= item.id %>/read?redirect=<%= filter %>" style="display:inline;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-submit" style="height:24px;font-size:11px;padding:0 10px;">Mark Read</button>
            </form>
          <% } %>
          <% if (item.email) { %>
            <details class="feedback-reply">
              <summary>Reply by email</summary>
              <form method="POST" action="/admin/feedback/<%= item.id %>/reply?redirect=<%= filter %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <textarea name="reply" rows="4" placeholder="Write reply to <%= item.email %>" required></textarea>
                <button type="submit" class="btn-submit" style="height:26px;font-size:11px;padding:0 12px;">Send Reply</button>
              </form>
            </details>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<%- include('partials/footer') %>
