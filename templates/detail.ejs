<%
  const pageTitle = theme.name + ' by ' + theme.author + ' — Renoise Theme Share';
  const pageDescription = (theme.description || 'A Renoise color theme').substring(0, 160);
  const ogTitle = theme.name + ' by ' + theme.author;
  const ogDescription = pageDescription;
%>
<%- include('partials/header', { pageTitle, pageDescription, ogTitle, ogDescription, ogImage }) %>

<%
  // Pick an accent color based on theme tags for dynamic UI tinting
  const accentMap = {
    red: 'red', orange: 'orange', yellow: 'yellow', green: 'green',
    cyan: 'cyan', blue: 'blue', purple: 'purple', pink: 'pink'
  };
  let accentColor = 'green';
  for (const tag of theme.tags) {
    if (accentMap[tag]) { accentColor = accentMap[tag]; break; }
  }
%>

<div class="detail-layout" data-accent="<%= accentColor %>" role="application" aria-label="Theme detail view">

  <!-- LEFT SIDEBAR: Track Info -->
  <aside class="detail-sidebar-left" aria-label="Theme information">
    <a href="/" class="back-link">← Back to browse</a>

    <div class="panel-section">
      <h1 class="detail-title"><%= theme.name %></h1>
      <p class="detail-meta">by <a href="/backstage/<%= encodeURIComponent(theme.author) %>" class="detail-author"><strong><%= theme.author %></strong></a></p>
      <p class="detail-meta"><%= new Date(theme.uploaded_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>

      <% if (user && user.username === theme.author) { %>
        <div style="margin: 4px 0 8px 0; display:flex;align-items:center;gap:8px;">
          <% if (theme.status === 'draft') { %>
            <span class="tag tag-draft" style="background:var(--chrome-warning);color:#111;font-weight:600;">Draft</span>
            <form action="/theme/<%= theme.slug %>/publish" method="POST" style="margin:0;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-submit" style="height:24px;font-size:10px;padding:0 8px;">Publish</button>
            </form>
          <% } else { %>
            <span class="tag tag-published" style="background:var(--chrome-success);color:#111;font-weight:600;">Published</span>
            <form action="/theme/<%= theme.slug %>/unpublish" method="POST" style="margin:0;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-submit" style="height:24px;font-size:10px;padding:0 8px;background:var(--chrome-warning);border-color:var(--chrome-warning);color:#111;">Unpublish</button>
            </form>
          <% } %>
          <a href="/theme/<%= theme.slug %>/edit" class="btn-submit" style="height:24px;font-size:10px;padding:0 8px;text-decoration:none;display:inline-flex;align-items:center;">Edit</a>
          <a href="/theme/<%= theme.slug %>/edit-colors" class="btn-submit" style="height:24px;font-size:10px;padding:0 8px;text-decoration:none;display:inline-flex;align-items:center;background:var(--accent);border-color:var(--accent);color:#111;">🎨 Colors</a>
          <form action="/theme/<%= theme.slug %>/delete" method="POST" style="margin:0;" onsubmit="return confirm('Delete this theme permanently?')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn-submit" style="height:24px;font-size:10px;padding:0 8px;background:var(--chrome-danger);border-color:var(--chrome-danger);">Delete</button>
          </form>
        </div>
      <% } %>

       <div class="detail-actions">
          <button class="btn-like" id="likeBtn" data-id="<%= theme.id %>" aria-label="Like this theme">
            <span id="likeIcon" aria-hidden="true">♥</span>
            <span id="likeCount"><%= theme.likes %></span>
          </button>
          <button class="btn-share" id="shareBtn" aria-label="Share theme link">
            Share
          </button>
          <% if (user) { %>
            <a href="/theme/<%= theme.slug %>/remix" class="btn-remix" aria-label="Remix this theme">
              ♻ Remix
            </a>
          <% } %>
          <a href="/download/<%= theme.slug %>" class="btn-primary btn-download" aria-label="Download theme file">
            ⬇ Download
          </a>
       </div>
    </div>

    <div class="panel-section">
      <h3>Stats</h3>
      <div class="detail-stats-grid">
        <div class="stat-cell">
          <span class="stat-value" id="likeCountStrip"><%= theme.likes %></span>
          <span class="stat-label">Likes</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value"><%= theme.downloads %></span>
          <span class="stat-label">Downloads</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value"><%= comments.length %></span>
          <span class="stat-label">Comments</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value"><%= theme.unique_colors %></span>
          <span class="stat-label">Colors</span>
        </div>
      </div>
    </div>

    <div class="panel-section">
      <h3>Prominent Colors</h3>
      <div class="color-swatches">
        <% theme.topColors.slice(0, 3).forEach(c => { %>
          <div class="color-swatch" data-color="#<%= c.hex %>" role="button" tabindex="0" aria-label="Copy hex color <%= c.hex %>">
            <div class="color-swatch-block" style="background:#<%= c.hex %>"></div>
            <code>#<%= c.hex %></code>
          </div>
        <% }); %>
      </div>
    </div>

    <div class="panel-section">
      <h3>Tags</h3>
      <div class="tags">
        <% theme.tags.forEach(tag => { %>
          <a href="/?tag=<%= tag %>" class="tag tag-<%= tag %>"><%= tag %></a>
        <% }); %>
      </div>
    </div>

    <div class="panel-section">
      <h3>Properties</h3>
      <div class="stat-bar-row">
        <span class="stat-bar-label">Lightness</span>
        <div class="stat-bar-track"><div class="stat-bar-fill" style="width:<%= theme.avg_lightness %>%"></div></div>
        <span class="stat-bar-value"><%= theme.avg_lightness %>%</span>
      </div>
      <div class="stat-bar-row">
        <span class="stat-bar-label">Saturation</span>
        <div class="stat-bar-track"><div class="stat-bar-fill" style="width:<%= theme.avg_saturation %>%"></div></div>
        <span class="stat-bar-value"><%= theme.avg_saturation %>%</span>
      </div>
      <div class="stat-bar-row">
        <span class="stat-bar-label">Contrast</span>
        <div class="stat-bar-track"><div class="stat-bar-fill" style="width:<%= theme.contrast_range %>%"></div></div>
        <span class="stat-bar-value"><%= theme.contrast_range %>%</span>
      </div>
    </div>
  </aside>

  <!-- MAIN: Preview + Content -->
  <div class="detail-main">

    <% const hasPreviews = theme.previewViews && theme.previewViews.includes('pattern'); %>

    <!-- Preview Viewport -->
    <div class="preview-viewport">
      <% if (hasPreviews) { %>
        <img
          class="preview-render"
          src="/uploads/previews/<%= theme.previewSlug %>/pattern.png"
          alt="Renoise Pattern Editor preview using the <%= theme.name %> color theme"
          loading="lazy"
          draggable="false"
        >
        <div class="preview-warning" role="alert">
          ⚠ Pixel mapping is approximate — not a 1:1 render yet
        </div>
      <% } else { %>
        <div class="preview-unavailable">
          <% if (theme.previewError) { %>
            ⚠ Preview generation failed: <%= theme.previewError %>
          <% } else { %>
            ℹ No preview available — check the palette below
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- Content sections below preview -->
    <div class="detail-sections">

      <!-- Description -->
      <% if (theme.description && theme.description.trim()) { %>
        <div class="detail-section-box">
          <h3>About</h3>
          <p><%= theme.description %></p>
        </div>
      <% } %>

      <!-- Gallery -->
      <% if (theme.screenshots.length > 0) { %>
        <div class="detail-section-box">
          <h3>Screenshots</h3>
          <div class="gallery-grid">
            <% theme.screenshots.forEach((ss, i) => { %>
              <div class="gallery-thumb <%= i === 0 ? 'gallery-active' : '' %>" data-src="/uploads/screenshots/<%= ss %>" tabindex="0" role="button" aria-label="View screenshot <%= i + 1 %>">
                <img src="/uploads/screenshots/<%= ss %>" alt="User screenshot <%= i + 1 %> of <%= theme.name %> theme" loading="lazy">
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>

      <!-- Palette strip (full width) -->
      <div class="detail-section-box">
        <h3>Full Palette</h3>
        <img src="<%= theme.palette_svg %>" alt="Complete color palette for <%= theme.name %> — <%= theme.unique_colors %> unique colors" style="width:100%; display:block; border:1px solid var(--chrome-border);">
      </div>

      <!-- Comments -->
      <div class="detail-section-box" id="comments">
        <h3>Comments (<%= comments.length %>)</h3>

        <form action="/theme/<%= theme.slug %>/comment" method="POST" class="comment-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label for="commentMessage" class="sr-only">Write a comment</label>
          <textarea id="commentMessage" name="message" placeholder="Leave a comment…" required maxlength="1000" rows="3"></textarea>
          <button type="submit">Post Comment</button>
        </form>

        <% if (comments.length === 0) { %>
          <p class="no-comments">No comments yet — be the first!</p>
        <% } else { %>
          <div class="comment-list">
            <% comments.forEach(c => { %>
              <article class="comment">
                <div class="comment-head">
                  <a href="/backstage/<%= encodeURIComponent(c.author) %>" class="comment-author"><strong><%= c.author %></strong></a>
                  <% if (c.author_title) { %><span class="flair"><%= c.author_title %></span><% } %>
                  <time datetime="<%= c.created_at %>"><%= new Date(c.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></time>
                </div>
                <p><%= c.message %></p>
              </article>
            <% }); %>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</div>

<!-- Toast notification -->
<div class="toast" id="toast" role="status" aria-live="polite" aria-atomic="true"></div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" role="dialog" aria-label="Image preview" aria-modal="true">
  <img id="lightboxImg" alt="">
</div>

<%- include('partials/footer') %>
