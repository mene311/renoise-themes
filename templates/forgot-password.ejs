<%- include('partials/header') %>

<section class="auth-page">
  <article class="auth-card">
    <h1>Forgot Password</h1>
    <p class="hero-sub">Enter your email and we'll send you a reset link.</p>

    <% if (error) { %>
      <div class="alert alert-error"><span class="alert-icon">❌</span><span><%= error %></span></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><span class="alert-icon">✅</span><span><%= success %></span></div>
    <% } %>

    <form action="/forgot-password" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label for="email">
        ✉️ Email
        <input type="email" id="email" name="email" placeholder="Your registered email" required>
      </label>

      <button type="submit" class="btn-submit">Send Reset Link</button>
    </form>

    <p class="auth-switch">
      <a href="/login">&larr; Back to login</a>
    </p>
  </article>
</section>

<%- include('partials/footer') %>
