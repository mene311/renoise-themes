<%- include('partials/header') %>

<section class="auth-page">
  <article class="auth-card">
    <h1>Log In</h1>
    <p class="hero-sub">Welcome back! Sign in to continue.</p>

    <% if (error) { %>
      <div class="alert alert-error"><span class="alert-icon">❌</span><span><%- error %></span></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><span class="alert-icon">✅</span><span><%= success %></span></div>
    <% } %>
    <% if (typeof verifyEmail !== "undefined" && verifyEmail) { %>
      <div class="alert" style="background:rgba(107,159,64,0.08);border:1px solid var(--accent);color:var(--accent);padding:10px 14px;margin-bottom:14px;font-size:13px;">
        <span>Didn't get the email? Check your spam folder or</span>
        <form method="POST" action="/resend-verification" style="display:inline;margin-left:4px;">
          <input type="hidden" name="email" value="<%= verifyEmail %>">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" style="background:none;border:none;color:var(--accent);cursor:pointer;text-decoration:underline;font-size:13px;padding:0;">resend verification</button>
        </form>
      </div>
    <% } %>

    <form action="/login" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label for="username">
        👤 Username
        <input type="text" id="username" name="username" placeholder="Your username" required>
      </label>

      <label for="password">
        🔑 Password
        <input type="password" id="password" name="password" placeholder="Your password" required>
      </label>

      <button type="submit" class="btn-submit">Log In</button>
    </form>

    <p class="auth-switch">
      <a href="/forgot-password">Forgot password?</a>
      &nbsp;·&nbsp;
      Don't have an account? <a href="/register">Sign up here</a>
    </p>
  </article>
</section>

<%- include('partials/footer') %>
