<!DOCTYPE html>
<html lang="en" data-theme="<%= uiTheme %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Renoise Theme Share' %></title>
  <meta name="description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : 'Upload, browse, and download Renoise color themes — auto-analyzed and tagged.' %>">

  <meta property="og:title" content="<%= typeof ogTitle !== 'undefined' ? ogTitle : 'Renoise Theme Share' %>">
  <meta property="og:description" content="<%= typeof ogDescription !== 'undefined' ? ogDescription : 'Community color themes for Renoise DAW — auto-analyzed with palettes and tags.' %>">
  <meta property="og:type" content="<%= typeof ogType !== 'undefined' ? ogType : 'website' %>">
  <% if (typeof ogImage !== 'undefined' && ogImage) { %>
  <meta property="og:image" content="<%= ogImage %>">
  <meta name="twitter:card" content="summary_large_image">
  <% } %>

  <style><%- _css %></style>
</head>
<body>

  <!-- Splash: vibe-coded disclaimer — shown once per visitor -->
  <div class="splash-overlay" id="vibeSplash">
    <div class="splash-card">
      <div class="splash-icon">⚠</div>
      <h2>Heads-up</h2>
      <p>This site was <strong>vibe-coded with AI</strong> — it's a hobby project, not a product.</p>
      <p class="splash-sub">If that bothers you, close the tab. Otherwise, carry on.</p>
      <button class="btn splash-dismiss" id="splashDismiss" onclick="var s=document.getElementById("vibeSplash");s.classList.add("splash-fade-out");setTimeout(function(){s.hidden=true},300);localStorage.setItem("splashDismissed","1")">Got it</button>
    </div>
  </div>
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label="Renoise Theme Share home">
        <span class="logo-icon" aria-hidden="true">◈</span>
        <span class="logo-text">Renoise<strong>Themes</strong></span>
      </a>

      <div class="header-search">
        <label for="headerSearchInput" class="sr-only">Search themes</label>
        <input type="search" id="headerSearchInput" placeholder="Search…" autocomplete="off" aria-label="Search themes">
      </div>

      <nav class="header-nav" aria-label="Main navigation">
        <a href="/">Browse</a>
          <a href="/tutorial">Tutorial</a>
          <a href="/create">Create</a>
        <% if (user) { %>
          <a href="/upload" class="btn-nav-upload">Upload</a>
          <a href="/backstage">Backstage</a>
          <% if (user.rank_level >= 5) { %>
          <% } %>
          <span class="nav-sep" aria-hidden="true"></span>
          <div class="user-menu" aria-label="User menu">
            <span class="user-avatar" aria-hidden="true"><%= user.username.charAt(0).toUpperCase() %></span>
            <a href="/backstage" class="user-name"><%= user.username %></a>
          </div>
          <a href="/logout">Logout</a>
        <% } else { %>
          <a href="/login">Log in</a>
          <a href="/register" class="btn-nav-upload">Sign up</a>
        <% } %>
      </nav>
    </div>
  </header>
  <main class="container" id="main-content">
