<!DOCTYPE html>
<html lang="en" data-theme="<%= uiTheme %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Renoise Theme Share</title>
  <meta name="description" content="Upload, browse, and download Renoise color themes — auto-analyzed and tagged.">

  <!-- Open Graph (social sharing previews) -->
  <meta property="og:title" content="Renoise Theme Share">
  <meta property="og:description" content="Community color themes for Renoise DAW — auto-analyzed with palettes and tags.">
  <meta property="og:type" content="website">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">
        <span class="logo-icon">🎵</span>
        <span class="logo-text">Renoise<strong>Themes</strong></span>
      </a>
      <div class="header-search">
        <input type="search" id="headerSearchInput" placeholder="Search..." autocomplete="off">
      </div>
      <nav class="header-nav">
        <a href="/set-theme/dark" class="theme-toggle <%= uiTheme === 'dark' ? 'theme-toggle-active' : '' %>" title="Dark">🌙</a>
        <a href="/set-theme/light" class="theme-toggle <%= uiTheme === 'light' ? 'theme-toggle-active' : '' %>" title="Light">☀️</a>
        <a href="/">Browse</a>
        <a href="/upload" class="btn-upload">⬆ Upload</a>
      </nav>
    </div>
  </header>
  <main class="container">
