<a href="/theme/<%= theme.slug || theme.id %>"
   class="theme-card"
   data-name="<%= theme.name.toLowerCase() %>"
   data-author="<%= theme.author.toLowerCase() %>"
   data-tags="<%= theme.tags.join(' ').toLowerCase() %>"
   aria-label="<%= theme.name %> by <%= theme.author %>, <%= theme.likes %> likes">

  <div class="card-preview" aria-hidden="true">
    <% const hasPreview = theme.previewSlug && theme.previewViews && theme.previewViews.includes('pattern'); %>
    <% if (hasPreview) { %>
      <img src="/uploads/previews/<%= theme.previewSlug %>/pattern.png"
           alt="Pattern Editor preview of <%= theme.name %>">
    <% } else if (theme.palette_svg) { %>
      <img src="<%= theme.palette_svg %>"
           alt="Color palette for <%= theme.name %>">
    <% } else { %>
      <div class="card-preview-empty">
        <span>◈</span>
      </div>
    <% } %>
  </div>

  <div class="card-info">
    <div class="card-title" title="<%= theme.name %>"><%= theme.name %></div>
    <div class="card-meta">
      <a href="/backstage/<%= theme.author %>" class="card-author" onclick="event.stopPropagation()"><%= theme.author %></a>
      <span class="card-likes" aria-label="<%= theme.likes %> likes">♥ <%= theme.likes %></span>
    </div>
  </div>

  <div class="card-palette" aria-hidden="true">
    <% if (theme.topColors && theme.topColors.length > 0) { %>
      <% theme.topColors.slice(0, 6).forEach(c => { %>
        <div style="background:#<%= c.hex %>; flex-grow:<%= Math.max(c.weight,1) %>"></div>
      <% }); %>
    <% } else { %>
      <div style="background:var(--chrome-border); flex:1"></div>
    <% } %>
  </div>
</a>
