<%- include('partials/header') %>

<section class="auth-page">
  <article class="auth-card">
    <h1>Create an Account</h1>
    <p class="hero-sub">Join the community to upload themes, leave comments, and build your profile.</p>

    <% if (error) { %>
      <div class="alert alert-error"><span class="alert-icon">❌</span><span><%= error %></span></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><span class="alert-icon">✅</span><span><%= success %></span></div>
    <% } %>

    <form action="/register" method="POST" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label for="username">
        👤 Username
        <input type="text" id="username" name="username" placeholder="Choose a username" required>
      </label>
      <small class="field-hint">This will be displayed on your themes and comments</small>

      <label for="email">
        ✉️ Email
        <input type="email" id="email" name="email" placeholder="Your email address" required>
      </label>
      <small class="field-hint">We'll never share your email with anyone</small>

      <label for="password">
        🔑 Password
        <input type="password" id="password" name="password" placeholder="At least 8 characters" required minlength="8">
      </label>

      <label for="passwordConfirm">
        🔑 Confirm Password
        <input type="password" id="passwordConfirm" name="passwordConfirm" placeholder="Type your password again" required minlength="8">
      </label>

      <button type="submit" class="btn-submit" id="regSubmitBtn">Create Account</button>
    </form>

    <p class="auth-switch">
      Already have an account? <a href="/login">Log in here</a>
    </p>
  </article>
</section>

<script>
(function() {
  var btn = document.getElementById('regSubmitBtn');
  if (!btn) return;
  btn.addEventListener('click', function(e) {
    var form = btn.closest('form');
    var u = form.querySelector('[name=username]').value.trim();
    var em = form.querySelector('[name=email]').value.trim();
    var pw = form.querySelector('[name=password]').value;
    var p2 = form.querySelector('[name=passwordConfirm]').value;
    var err = '';
    if (!u) err = 'Username is required';
    else if (u.length < 2 || u.length > 30) err = 'Username must be 2-30 characters';
    else if (!/^[a-zA-Z0-9_-]+$/.test(u)) err = 'Username can only contain letters, numbers, _ or -';
    else if (!em) err = 'Email is required';
    else if (!/^[^@]+@[^@]+\.[^@]+$/.test(em)) err = 'Please enter a valid email address';
    else if (!pw) err = 'Password is required';
    else if (pw.length < 8) err = 'Password must be at least 8 characters';
    else if (pw !== p2) err = 'Passwords do not match';
    if (err) {
      e.preventDefault();
      var old = form.querySelector('.alert-error');
      if (old) old.remove();
      var div = document.createElement('div');
      div.className = 'alert alert-error';
      div.innerHTML = '<span class="alert-icon">❌</span><span>' + err + '</span>';
      form.insertBefore(div, form.firstChild);
      div.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });
})();
</script>

<%- include('partials/footer') %>
