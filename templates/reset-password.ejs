<%- include('partials/header') %>

<section class="auth-page">
  <article class="auth-card">
    <h1>Reset Password</h1>
    <p class="hero-sub">Choose a new password for your account.</p>

    <% if (error) { %>
      <div class="alert alert-error"><span class="alert-icon">❌</span><span><%= error %></span></div>
    <% } %>

    <% if (token) { %>
    <form action="/reset-password/<%= token %>" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label for="password">
        🔑 New Password
        <input type="password" id="password" name="password" placeholder="At least 8 characters" required minlength="8">
      </label>

      <label for="passwordConfirm">
        🔑 Confirm Password
        <input type="password" id="passwordConfirm" name="passwordConfirm" placeholder="Type it again" required minlength="8">
      </label>

      <button type="submit" class="btn-submit">Reset Password</button>
    </form>
    <% } else { %>
      <p class="auth-switch">
        <a href="/forgot-password">Request a new reset link</a> or <a href="/login">log in</a>
      </p>
    <% } %>
  </article>
</section>

<%- include('partials/footer') %>
