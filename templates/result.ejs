<%- include('partials/header') %>

<section class="result-page">
  <h1>✅ Theme Uploaded!</h1>

  <article>
    <header>
      <h2><%= theme.originalName %></h2>
      <small>by <a href="/backstage/<%= encodeURIComponent(theme.author) %>"><strong><%= theme.author %></strong></a></small>
    </header>

    <h3>Color Palette</h3>
    <img
      src="<%= theme.paletteSVG %>"
      alt="Color palette for <%= theme.originalName %>"
      style="width: 100%; display: block; border: 1px solid var(--chrome-border);"
    >

    <h3>Most Prominent Colors</h3>
    <div class="color-swatches">
      <% theme.topColors.slice(0, 3).forEach(c => { %>
        <div class="color-swatch" data-color="#<%= c.hex %>" role="button" tabindex="0" aria-label="Copy hex color <%= c.hex %>">
          <div class="color-swatch-block" style="background:#<%= c.hex %>"></div>
          <code>#<%= c.hex %></code>
        </div>
      <% }); %>
    </div>

    <h3>Auto-Tags</h3>
    <div class="tags">
      <% theme.tags.forEach(tag => { %>
        <span class="tag tag-<%= tag %>"><%= tag %></span>
      <% }); %>
    </div>

    <h3>Stats</h3>
    <table>
      <tr><td>Unique colors</td><td><strong><%= theme.stats.totalUnique %></strong></td></tr>
      <tr><td>Chromatic (colorful)</td><td><strong><%= theme.stats.chromaticCount %></strong></td></tr>
      <tr><td>Avg lightness (weighted)</td><td><strong><%= theme.stats.avgLightness %>%</strong></td></tr>
      <tr><td>Avg saturation (weighted)</td><td><strong><%= theme.stats.avgSaturation %>%</strong></td></tr>
      <tr><td>Contrast range</td><td><strong><%= theme.stats.contrastRange %>%</strong></td></tr>
    </table>

    <% if (theme.screenshot) { %>
      <h3>Screenshot</h3>
      <img src="/uploads/screenshots/<%= theme.screenshot %>" alt="Screenshot of <%= theme.originalName %>" style="width: 100%; display: block; border: 1px solid var(--chrome-border);">
    <% } %>

    <footer>
      <a href="/upload">Upload Another</a>
      <a href="/" role="button">Browse All</a>
    </footer>
  </article>
</section>

<%- include('partials/footer') %>
